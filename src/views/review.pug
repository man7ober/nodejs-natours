extends base

block content 
  main.main 
    if review
      .card-container
        for review in reviews 
          .card 
            .card__header
              .card__picture
                .card__picture-overlay &nbsp;
                img.card__picture-img(src=`/img/tours/${review.tour.imageCover}`, alt=`${review.tour.name}`)
              h3.heading-tertirary
                p.card__text #{review.createdAt.toLocaleDateString('en-US', {day:"numeric", year:"numeric", month:"short"})} 
                span #{review.tour.name} 

            .card__footer
              p
                span.card__footer-value Rating - #{review.rating}
              p.card__ratings
                span.card__footer-value Review - #{review.review}} 
    else 
      .error
        .error__title
          h2.heading-secondary.heading-secondary--error No Reviews Yet 
        h2.error__emoji
        .error__msg 🥺 Please review something! 😟